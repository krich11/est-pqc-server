# EST Server example configuration
#
# This file is both:
# 1. A documented reference for administrators
# 2. A known-good sample that runs with the demo certificates in this repository
#
# Runtime usage:
#   ./target/release/est-server --config ./config.toml.example
#
# CLI overrides are also supported for every item below. Example:
#   ./target/release/est-server \
#     --config ./config.toml.example \
#     --listen-address 127.0.0.1 \
#     --listen-port 9443 \
#     --openssl-binary openssl
#
# Notes:
# - EST requires TLS 1.3 only in this implementation.
# - Relative paths are resolved from the current working directory.
# - This sample assumes the process is started from the repository root.
# - The values below are intentionally set to a known-good demo configuration.
# - OpenSSL binaries are now auto-discovered; `openssl_binary` stores the selected binary.

# Address to bind for incoming EST HTTPS traffic.
listen_address = "0.0.0.0"

# TCP port for the EST listener.
listen_port = 8443

# EST server requires TLS 1.3.
tls_version = "TLS1.3"

# Preferred TLS 1.3 cipher suite for the listener.
preferred_tls_cipher_suite = "TLS_AES_256_GCM_SHA384"

# Server-generated key type used by the RFC 7030 serverkeygen endpoint.
# Supported values:
# - "rsa2048"
# - "rsa3072"
# - "rsa4096"
# - "ecdsa-p256"
# - "ecdsa-p384"
# - "ml-dsa65"
# - "ml-dsa87"
#
# For Linux hosts using OpenSSL 3.0.x, "rsa2048" is the safest known-good choice.
key_type = "rsa2048"

# Enable FIPS mode if the active system OpenSSL provider set supports it.
enable_fips = false

# Optional legacy OpenSSL installation root.
# Leave empty for automatic discovery from OPENSSL or PATH.
openssl_dir = ""

# Selected OpenSSL CLI binary used for PKCS#7, CMS, CSR, and certificate operations.
# Using "openssl" allows the system PATH to supply the discovered binary.
openssl_binary = "openssl"

# Selected OpenSSL providers passed to CLI-backed operations.
# Choose one or more provider names discovered on the host, such as "default" or "fips".
openssl_providers = ["default"]

# Issuing CA certificate used for cacerts responses and EST-issued certificate chains.
ca_certificate_path = "demo/demo-ca.crt"

# Issuing CA private key used to sign EST-issued certificates.
ca_private_key_path = "demo/demo-ca.key"

# Trust anchor used by the TLS listener to validate client certificates for mTLS.
client_auth_ca_certificate_path = "demo/demo-ca.crt"

# TLS server certificate presented by the EST HTTPS listener.
tls_certificate_path = "demo/rsa-2048-server.crt"

# TLS private key corresponding to tls_certificate_path.
tls_private_key_path = "demo/rsa-2048-server.key"

# Directory used to persist completed EST enrollment artifacts.
enrollment_storage_dir = "logs/enrollments"

# Directory used to persist deferred EST enrollment state.
pending_enrollment_dir = "logs/pending"

# Maximum accepted EST HTTP request body size in bytes.
max_request_body_bytes = 1048576

# Default Retry-After value for deferred EST operations.
default_retry_after_seconds = 60

# Recorded platform capability flags.
# These are informational unless explicitly overridden on the CLI.
ml_kem_supported = true
ml_dsa_supported = false

[webui]
enabled = true
listen_address = "0.0.0.0"
listen_port = 9443
# Leave these empty to auto-generate a unique self-signed HTTPS certificate for the WebUI.
# Set both paths explicitly to use an operator-provided certificate and key instead.
tls_certificate_path = ""
tls_private_key_path = ""
auth_mode = "basic"
admin_username = "admin"
admin_password_hash = "$argon2id$v=19$m=19456,t=2,p=1$VRUPCgBrVELjPii4IB4GBQ$3IsfqTxBcWbQPziNjKF5ZaM+WLtWT9RddlUSFDmZo8k"
systemd_unit_name = "est-server"

[[webui.users]]
username = "admin"
password_hash = "$argon2id$v=19$m=19456,t=2,p=1$VRUPCgBrVELjPii4IB4GBQ$3IsfqTxBcWbQPziNjKF5ZaM+WLtWT9RddlUSFDmZo8k"
role = "super-admin"
enabled = true

[[webui.users]]
username = "krich"
password_hash = "$argon2id$v=19$m=19456,t=2,p=1$QOZpp4fQ6QmxqKTOih5DAw$uVZhygTJlXhfGEQ8WL/lFGjJi3EqEs1bSolj+oczK8k"
role = "admin"
